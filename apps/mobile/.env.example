EXPO_PUBLIC_ANTHROPIC_API_KEY=your_key_here

# For local/mobile development only.
# In production, route AI API calls through a backend service
# so this key is never shipped in the app bundle.

# --- Local AI (Ollama) - used when EXPO_PUBLIC_USE_LOCAL_AI=true ---
# Default to true for integration so the app uses Ollama without an API key.
EXPO_PUBLIC_USE_LOCAL_AI=true
EXPO_PUBLIC_LOCAL_AI_URL=http://localhost:11434
# Optional. Model name (e.g. phi4-mini:latest, llama3.1:8b). Default in code if unset.
EXPO_PUBLIC_LOCAL_AI_MODEL=phi4-mini:latest

# Network notes for local AI:
# - Physical device: localhost is the phone. Use your computer's LAN IP (e.g. http://192.168.1.100:11434).
# - Android emulator: use http://10.0.2.2:11434 to reach host's localhost:11434.
# - iOS simulator: http://localhost:11434 often works.

